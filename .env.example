# ---- LINE Developers Console > your Messaging API channel ----
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ---- Google Cloud > Service Account (with Sheets API enabled) ----
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private key from the service account JSON. Keep the \n escape sequences as-is.
GOOGLE_PRIVATE_KEY=

# ---- The Google Sheet you created and shared with the service account email above ----
GOOGLE_SHEET_ID=

PORT=3000
